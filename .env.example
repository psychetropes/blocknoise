# server/.env — secret keys, never committed
ELEVENLABS_API_KEY=           # elevenlabs api key for sound generation
SUPABASE_URL=                 # supabase project url (https://xxx.supabase.co)
SUPABASE_SERVICE_KEY=         # supabase service role key (server-side only)
SOLANA_RPC=                   # server-side solana rpc (default: https://api.devnet.solana.com)
SOLANA_NETWORK=               # 'devnet' or 'mainnet' (used by irys for arweave uploads)
IRYS_WALLET_KEY=              # base58 private key for irys arweave uploads (REQUIRED)
TREASURY_ADDRESS=             # solana wallet to receive mint payments (REQUIRED, must match client)
CORS_ORIGINS=                 # comma-separated allowed origins (empty = allow all for dev)

# app/.env — non-sensitive client config
EXPO_PUBLIC_API_URL=          # express server url (e.g. http://192.168.1.x:3001)
EXPO_PUBLIC_SOLANA_NETWORK=   # 'devnet' or 'mainnet' (default: devnet)
EXPO_PUBLIC_SOLANA_RPC=       # solana rpc endpoint (default: https://api.devnet.solana.com)
EXPO_PUBLIC_SUPABASE_URL=     # supabase project url (same as above, used client-side)
EXPO_PUBLIC_SUPABASE_ANON_KEY= # supabase anon/public key (safe for client)
EXPO_PUBLIC_TREASURY_ADDRESS= # solana wallet to receive mint payments (must match server)
