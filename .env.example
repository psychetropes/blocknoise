# server/.env — secret keys, never committed
ELEVENLABS_API_KEY=           # elevenlabs api key for sound generation
SUPABASE_URL=                 # supabase project url (https://xxx.supabase.co)
SUPABASE_SERVICE_KEY=         # supabase service role key (server-side only)

# app/.env — non-sensitive client config
EXPO_PUBLIC_API_URL=          # express server url (e.g. http://192.168.1.x:3001)
EXPO_PUBLIC_SOLANA_RPC=       # solana rpc endpoint (default: https://api.mainnet-beta.solana.com)
EXPO_PUBLIC_SUPABASE_URL=     # supabase project url (same as above, used client-side)
EXPO_PUBLIC_SUPABASE_ANON_KEY= # supabase anon/public key (safe for client)
